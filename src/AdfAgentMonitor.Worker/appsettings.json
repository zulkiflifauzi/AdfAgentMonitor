{
  // ============================================================================
  // CONNECTION STRINGS
  // Env var: CONNECTIONSTRINGS__DEFAULTCONNECTION
  // Used by EF Core. Hangfire falls back to this when Hangfire:SqlConnectionString
  // is not set.
  // ============================================================================
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  // ============================================================================
  // AZURE DATA FACTORY
  // Required fields: SubscriptionId, ResourceGroup, FactoryName
  // SP credentials (TenantId / ClientId / ClientSecret): fill all three to use
  //   ClientSecretCredential; leave all empty to use DefaultAzureCredential
  //   (Managed Identity, az login, AZURE_* env vars).
  // Env vars: AZUREDATAFACTORY__SUBSCRIPTIONID  AZUREDATAFACTORY__RESOURCEGROUP
  //           AZUREDATAFACTORY__FACTORYNAME      AZUREDATAFACTORY__TENANTID
  //           AZUREDATAFACTORY__CLIENTID         AZUREDATAFACTORY__CLIENTSECRET
  //           AZUREDATAFACTORY__DEFAULTINTEGRATIONRUNTIMENAME
  // ============================================================================
  "AzureDataFactory": {
    "SubscriptionId": "",
    "ResourceGroup": "",
    "FactoryName": "",
    "TenantId": "",
    "ClientId": "",
    "ClientSecret": "",
    "LookbackMinutes": 60,
    "DefaultIntegrationRuntimeName": ""
  },

  // ============================================================================
  // MICROSOFT TEAMS  (Microsoft Graph API) — kept for reference, no longer used
  // ============================================================================
  "Teams": {
    "TeamId": "",
    "ChannelId": "",
    "ApprovalWebhookBaseUrl": ""
  },

  // ============================================================================
  // EMAIL NOTIFICATIONS  (MailKit SMTP)
  // Env vars: EMAIL__SMTPHOST  EMAIL__SMTPPORT  EMAIL__USESSL
  //           EMAIL__USERNAME  EMAIL__PASSWORD
  //           EMAIL__FROMADDRESS  EMAIL__FROMNAME  EMAIL__DASHBOARDBASEURL
  // ============================================================================
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "ADF Agent Monitor",
    "DashboardBaseUrl": ""
  },

  // ============================================================================
  // ANTHROPIC / CLAUDE
  // ApiKey — Anthropic API key. NEVER commit a real value to source control.
  // Env vars: ANTHROPIC__APIKEY  ANTHROPIC__MODELID
  // ============================================================================
  "Anthropic": {
    "ApiKey": "",
    "ModelId": "claude-sonnet-4-20250514",
    "Temperature": 0.0,
    "MaxTokens": 1024
  },

  // ============================================================================
  // HANGFIRE
  // SqlConnectionString — dedicated connection string for Hangfire's job-store
  //   schema. Falls back to ConnectionStrings:DefaultConnection when empty,
  //   which is sufficient for local development with a single database.
  // Env vars: HANGFIRE__SQLCONNECTIONSTRING  HANGFIRE__WORKERCOUNT
  // ============================================================================
  "Hangfire": {
    "SqlConnectionString": "",
    "WorkerCount": 5
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Hangfire": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
