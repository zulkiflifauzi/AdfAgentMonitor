{
  // Local development overrides — never commit real secrets here.
  // Use `dotnet user-secrets set` for ApiKey / ClientSecret / Anthropic:ApiKey.

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AdfAgentMonitor;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "AzureDataFactory": {
    // Leave TenantId / ClientId / ClientSecret empty locally to use DefaultAzureCredential
    // (picks up `az login` or AZURE_* environment variables automatically).
    "LookbackMinutes": 120
  },

  "Hangfire": {
    // Falls back to ConnectionStrings:DefaultConnection — no separate entry needed locally.
    "SqlConnectionString": "",
    "WorkerCount": 2
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Hangfire": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}
