@page "/settings"
@inject IJSRuntime               JS
@inject IMonitorApiClient        ApiClient
@inject LayoutState              LayoutState
@inject ISnackbar                Snackbar
@inject DashboardSettingsService DashboardSettings
@inject IOptions<ApiClientSettings> ApiSettings
@implements IAsyncDisposable

<PageTitle>Settings — ADF Agent Monitor</PageTitle>

<MudStack Spacing="5">

    @* ── Page header ─────────────────────────────────────────────────────── *@

    <div>
        <MudText Typo="Typo.h4" Style="font-weight:700">Settings</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Connection, notification, and display preferences.
        </MudText>
    </div>

    @* ── Tabs ─────────────────────────────────────────────────────────────── *@

    <MudTabs Elevation="1"
             Rounded="true"
             ApplyEffectsToContainer="true"
             PanelClass="pa-6"
             Color="Color.Primary">

        @* ════════════════════════════════════════════════════════════════════
           Tab 1 — Connection
           ════════════════════════════════════════════════════════════════════ *@

        <MudTabPanel Text="Connection" Icon="@Icons.Material.Filled.Cable">
            <MudStack Spacing="5">

                @* Current live status *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@(LayoutState.IsApiConnected
                                         ? Icons.Material.Filled.CheckCircle
                                         : Icons.Material.Filled.Error)"
                             Color="@(LayoutState.IsApiConnected ? Color.Success : Color.Error)"
                             Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        @(LayoutState.IsApiConnected ? "Connected to API" : "API unreachable")
                    </MudText>
                </MudStack>

                <MudDivider />

                @* Editable fields *@
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_apiBaseUrl"
                                  Label="API Base URL"
                                  Variant="Variant.Outlined"
                                  Placeholder="https://your-api.example.com/"
                                  HelperText="Override the URL from appsettings.json. Leave blank to use the default."
                                  InputType="InputType.Url"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Link" />

                    <MudTextField @bind-Value="_apiKey"
                                  Label="API Key"
                                  Variant="Variant.Outlined"
                                  Placeholder="Leave blank to use the default from appsettings.json"
                                  HelperText="Override the X-Api-Key header. Leave blank to use the default."
                                  InputType="@(_showKey ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showKey
                                      ? Icons.Material.Filled.VisibilityOff
                                      : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showKey = !_showKey)" />
                </MudStack>

                <MudAlert Severity="Severity.Info" Dense="true">
                    Values entered here override <code>wwwroot/appsettings.json</code> and
                    take effect immediately in the current session. They are also saved to
                    <code>localStorage</code> so they persist across reloads.
                    Leave a field blank to revert to the appsettings.json default.
                </MudAlert>

                @* Action buttons *@
                <MudStack Row="true" Spacing="2" Class="flex-wrap">

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@_savingConnection"
                               OnClick="@SaveConnectionAsync">
                        @if (_savingConnection)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            <text>Saving…</text>
                        }
                        else
                        {
                            <text>Save</text>
                        }
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.NetworkCheck"
                               Disabled="@_testingConnection"
                               OnClick="@RunTestConnectionAsync">
                        @if (_testingConnection)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            <text>Testing…</text>
                        }
                        else
                        {
                            <text>Test Connection</text>
                        }
                    </MudButton>

                    @if (DashboardSettings.HasBaseUrlOverride || DashboardSettings.HasApiKeyOverride)
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                   OnClick="@ClearConnectionOverridesAsync">
                            Reset to defaults
                        </MudButton>
                    }

                </MudStack>

            </MudStack>
        </MudTabPanel>

        @* ════════════════════════════════════════════════════════════════════
           Tab 2 — Notifications
           ════════════════════════════════════════════════════════════════════ *@

        <MudTabPanel Text="Notifications" Icon="@Icons.Material.Filled.Notifications">
            <MudStack Spacing="4">

                @* Email recipients *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Style="font-weight:600">Email notification recipients</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Email addresses that receive pipeline failure and approval notifications.
                            </MudText>
                        </MudStack>

                        @* Current recipients as chips *@
                        @if (_recipientEmails.Count > 0)
                        {
                            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                                @foreach (var email in _recipientEmails)
                                {
                                    <MudChip T="string"
                                             Text="@email"
                                             Color="Color.Primary"
                                             Variant="Variant.Outlined"
                                             OnClose="@(() => RemoveRecipient(email))"
                                             CloseIcon="@Icons.Material.Filled.Close" />
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">No recipients configured.</MudText>
                        }

                        @* Add new recipient *@
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudTextField @bind-Value="_newRecipientEmail"
                                          Label="Add Email"
                                          Variant="Variant.Outlined"
                                          Placeholder="ops-team@example.com"
                                          InputType="InputType.Email"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Email"
                                          Margin="Margin.Dense"
                                          Style="flex:1"
                                          OnKeyDown="@OnAddEmailKeyDown" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@AddRecipient"
                                       Disabled="@string.IsNullOrWhiteSpace(_newRecipientEmail)">
                                Add
                            </MudButton>
                        </MudStack>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@_savingRecipient"
                                   OnClick="@SaveRecipientsAsync">
                            @if (_savingRecipient) { <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" /><text>Saving…</text> }
                            else { <text>Save</text> }
                        </MudButton>
                    </MudStack>
                </MudPaper>

                <MudDivider />

                @* Permission status banner *@
                @if (_notificationPermission == "denied")
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Browser notifications have been <strong>blocked</strong>. To re-enable them,
                        click the lock icon in your browser's address bar and allow notifications for
                        this site.
                    </MudAlert>
                }
                else if (_notificationPermission == "unsupported")
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Your browser does not support the Web Notifications API.
                    </MudAlert>
                }

                @* Master enable *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Style="font-weight:600">
                                Enable browser notifications
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Requests Notification API permission and enables in-browser alerts.
                            </MudText>
                        </MudStack>
                        <MudSwitch T="bool"
                                   Value="@_notificationsEnabled"
                                   ValueChanged="@OnNotificationsEnabledChangedAsync"
                                   Color="Color.Primary"
                                   Disabled="@(_notificationPermission is "denied" or "unsupported")" />
                    </MudStack>
                </MudPaper>

                @* Per-event switches *@

                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">New pipeline failure</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Notify when MonitorAgent detects a new failed run.
                            </MudText>
                        </MudStack>
                        <MudSwitch T="bool"
                                   Value="_notifyOnFailure"
                                   ValueChanged="@((bool v) => { _notifyOnFailure = v; _ = SaveNotificationsAsync(); })"
                                   Color="Color.Primary"
                                   Disabled="@(!_notificationsEnabled)" />
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Pending approval</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Notify when a remediation plan is waiting for your sign-off.
                            </MudText>
                        </MudStack>
                        <MudSwitch T="bool"
                                   Value="_notifyOnApproval"
                                   ValueChanged="@((bool v) => { _notifyOnApproval = v; _ = SaveNotificationsAsync(); })"
                                   Color="Color.Primary"
                                   Disabled="@(!_notificationsEnabled)" />
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Auto-remediation complete</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Notify when FixAgent resolves a pipeline run automatically.
                            </MudText>
                        </MudStack>
                        <MudSwitch T="bool"
                                   Value="_notifyOnRemediation"
                                   ValueChanged="@((bool v) => { _notifyOnRemediation = v; _ = SaveNotificationsAsync(); })"
                                   Color="Color.Primary"
                                   Disabled="@(!_notificationsEnabled)" />
                    </MudStack>
                </MudPaper>

            </MudStack>
        </MudTabPanel>

        @* ════════════════════════════════════════════════════════════════════
           Tab 3 — Email Settings
           ════════════════════════════════════════════════════════════════════ *@

        <MudTabPanel Text="Email" Icon="@Icons.Material.Filled.AlternateEmail">
            <MudStack Spacing="4">

                @if (_emailSettings?.HasOverrides == true)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Some settings are overriding <code>appsettings.json</code>. Click
                        <strong>Clear overrides</strong> to revert all fields to their server defaults.
                    </MudAlert>
                }

                @* SMTP *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body1" Style="font-weight:600">SMTP server</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudTextField @bind-Value="_emailSmtpHost"
                                          Label="SMTP Host"
                                          Variant="Variant.Outlined"
                                          Placeholder="smtp.example.com"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Dns"
                                          Style="flex:1"
                                          Margin="Margin.Dense" />
                            <MudNumericField T="int?"
                                             @bind-Value="_emailSmtpPort"
                                             Label="Port"
                                             Variant="Variant.Outlined"
                                             Placeholder="587"
                                             Style="width:100px"
                                             Margin="Margin.Dense" />
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2">Use STARTTLS</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Encrypt the connection with STARTTLS.</MudText>
                            </MudStack>
                            <MudSwitch T="bool?" Value="@_emailUseSsl"
                                       ValueChanged="@((bool? v) => _emailUseSsl = v)"
                                       Color="Color.Primary" />
                        </MudStack>
                    </MudStack>
                </MudPaper>

                @* Auth *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body1" Style="font-weight:600">Authentication</MudText>
                        <MudTextField @bind-Value="_emailUsername"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      Placeholder="Leave blank for unauthenticated relays"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_emailPassword"
                                      Label="@(_emailSettings?.HasPassword == true ? "Password (set — enter new value to change)" : "Password")"
                                      Variant="Variant.Outlined"
                                      Placeholder="@(_emailSettings?.HasPassword == true ? "Leave blank to keep existing password" : "Enter SMTP password")"
                                      InputType="@(_showEmailPassword ? InputType.Text : InputType.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showEmailPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentClick="@(() => _showEmailPassword = !_showEmailPassword)"
                                      Margin="Margin.Dense" />
                    </MudStack>
                </MudPaper>

                @* Sender *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body1" Style="font-weight:600">Sender</MudText>
                        <MudTextField @bind-Value="_emailFromAddress"
                                      Label="From Address"
                                      Variant="Variant.Outlined"
                                      Placeholder="adfmonitor@example.com"
                                      InputType="InputType.Email"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email"
                                      Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_emailFromName"
                                      Label="From Name"
                                      Variant="Variant.Outlined"
                                      Placeholder="ADF Agent Monitor"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Badge"
                                      Margin="Margin.Dense" />
                    </MudStack>
                </MudPaper>

                @* Links *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Style="font-weight:600">Dashboard base URL</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Used to build the "Open Approvals Dashboard" link in approval emails.
                            </MudText>
                        </MudStack>
                        <MudTextField @bind-Value="_emailDashboardBaseUrl"
                                      Label="Dashboard Base URL"
                                      Variant="Variant.Outlined"
                                      Placeholder="https://dashboard.example.com"
                                      InputType="InputType.Url"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Link"
                                      Margin="Margin.Dense" />
                    </MudStack>
                </MudPaper>

                <MudAlert Severity="Severity.Info" Dense="true">
                    Only fields you fill in will override the server-side <code>appsettings.json</code> values.
                    Clear a field to remove that override and revert to the server default.
                </MudAlert>

                <MudDivider />

                @* Test email *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Spacing="3">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Style="font-weight:600">Test configuration</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Send a test email using the current settings above (saved overrides + appsettings).
                                Save your changes first if you want to test a new configuration.
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudTextField @bind-Value="_testEmailRecipient"
                                          Label="Send test to"
                                          Variant="Variant.Outlined"
                                          Placeholder="you@example.com"
                                          InputType="InputType.Email"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Send"
                                          Margin="Margin.Dense"
                                          Style="flex:1"
                                          OnKeyDown="@OnTestEmailKeyDown" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Email"
                                       Disabled="@(_sendingTestEmail || string.IsNullOrWhiteSpace(_testEmailRecipient))"
                                       OnClick="@SendTestEmailAsync">
                                @if (_sendingTestEmail)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                                    <text>Sending…</text>
                                }
                                else { <text>Send Test</text> }
                            </MudButton>
                        </MudStack>
                        @if (_testEmailResult is not null)
                        {
                            <MudAlert Severity="@(_testEmailResult.Value.Success ? Severity.Success : Severity.Error)"
                                      Dense="true">
                                @_testEmailResult.Value.Message
                            </MudAlert>
                        }
                    </MudStack>
                </MudPaper>

                @* Action buttons *@
                <MudStack Row="true" Spacing="2" Class="flex-wrap">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@_savingEmailSettings"
                               OnClick="@SaveEmailSettingsAsync">
                        @if (_savingEmailSettings)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            <text>Saving…</text>
                        }
                        else { <text>Save</text> }
                    </MudButton>
                    @if (_emailSettings?.HasOverrides == true)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.RestartAlt"
                                   Disabled="@_savingEmailSettings"
                                   OnClick="@ClearEmailSettingsAsync">
                            Clear overrides
                        </MudButton>
                    }
                </MudStack>

            </MudStack>
        </MudTabPanel>

        @* ════════════════════════════════════════════════════════════════════
           Tab 4 — Display
           ════════════════════════════════════════════════════════════════════ *@

        <MudTabPanel Text="Display" Icon="@Icons.Material.Filled.DisplaySettings">
            <MudStack Spacing="4">

                @* Dark mode *@
                <MudPaper Elevation="0"
                          Style="border:1px solid var(--mud-palette-divider); border-radius:8px"
                          Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center"
                              Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1" Style="font-weight:600">Dark mode</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Toggle between dark and light theme.
                            </MudText>
                        </MudStack>
                        <MudSwitch T="bool"
                                   Value="@LayoutState.IsDarkMode"
                                   ValueChanged="@SetDarkModeAsync"
                                   Color="Color.Primary" />
                    </MudStack>
                </MudPaper>

                <MudDivider />

                @* Refresh interval *@
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body1" Style="font-weight:600">
                        Dashboard refresh interval
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        How often the pending-approval count and connection status refresh.
                    </MudText>
                    <MudSelect T="int"
                               Value="@_refreshInterval"
                               ValueChanged="@SaveRefreshIntervalAsync"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Style="max-width:260px"
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var (label, val) in _refreshOptions)
                        {
                            <MudSelectItem T="int" Value="@val">@label</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>

            </MudStack>
        </MudTabPanel>

    </MudTabs>

    @* ── About ────────────────────────────────────────────────────────────── *@

    <MudPaper Elevation="1" Class="pa-5">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h6" Style="font-weight:600">About</MudText>
            <MudDivider />
            <MudStack Spacing="2">
                @foreach (var (label, value) in _aboutRows)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="min-width:160px">@label</MudText>
                        <MudText Typo="Typo.body2">@value</MudText>
                    </MudStack>
                }
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="min-width:160px">Last Refreshed</MudText>
                    <MudText Typo="Typo.body2">
                        @(LayoutState.LastRefreshed.HasValue
                            ? LayoutState.LastRefreshed.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            : "—")
                    </MudText>
                </MudStack>
            </MudStack>
        </MudStack>
    </MudPaper>

</MudStack>

@code {

    // ── Static data ───────────────────────────────────────────────────────────

    private static readonly (string Label, int Value)[] _refreshOptions =
    [
        ("15 seconds",  15),
        ("30 seconds",  30),
        ("1 minute",    60),
        ("5 minutes",   300),
    ];

    private static readonly (string Label, string Value)[] _aboutRows =
    [
        ("Application", "ADF Agent Monitor Dashboard"),
        ("Framework",   "Blazor WebAssembly · .NET 9"),
        ("UI Library",  "MudBlazor v7"),
    ];

    // ── State — Connection ────────────────────────────────────────────────────

    private string _apiBaseUrl       = string.Empty;
    private string _apiKey           = string.Empty;
    private bool   _showKey;
    private bool   _savingConnection;
    private bool   _testingConnection;

    // ── State — Notifications ─────────────────────────────────────────────────

    private List<string> _recipientEmails    = [];
    private string       _newRecipientEmail  = string.Empty;
    private bool         _savingRecipient;

    private string _notificationPermission = "default";
    private bool   _notificationsEnabled;
    private bool   _notifyOnFailure    = true;
    private bool   _notifyOnApproval   = true;
    private bool   _notifyOnRemediation;

    // ── State — Email Settings ────────────────────────────────────────────────

    private EmailSettingsDto? _emailSettings;
    private string  _emailSmtpHost        = string.Empty;
    private int?    _emailSmtpPort;
    private bool?   _emailUseSsl;
    private string  _emailUsername        = string.Empty;
    private string  _emailPassword        = string.Empty;
    private string  _emailFromAddress     = string.Empty;
    private string  _emailFromName        = string.Empty;
    private string  _emailDashboardBaseUrl = string.Empty;
    private bool    _showEmailPassword;
    private bool    _savingEmailSettings;
    private string  _testEmailRecipient  = string.Empty;
    private bool    _sendingTestEmail;
    private (bool Success, string Message)? _testEmailResult;

    // ── State — Display ───────────────────────────────────────────────────────

    private int _refreshInterval = 30;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        // Connection
        _apiBaseUrl = await GetStoredAsync("adf:settings:apiBaseUrl") ?? string.Empty;
        _apiKey     = await GetStoredAsync("adf:settings:apiKey")     ?? string.Empty;

        // Notifications — email recipients
        try { _recipientEmails = await ApiClient.GetNotificationRecipientsAsync(_cts.Token); }
        catch { _recipientEmails = []; }

        // Notifications
        try { _notificationPermission = await JS.InvokeAsync<string>("adfNotifications.getPermission"); }
        catch { _notificationPermission = "unsupported"; }

        _notificationsEnabled = ParseBool(await GetStoredAsync("adf:settings:notificationsEnabled"), false);
        _notifyOnFailure      = ParseBool(await GetStoredAsync("adf:settings:notifyOnFailure"),    true);
        _notifyOnApproval     = ParseBool(await GetStoredAsync("adf:settings:notifyOnApproval"),   true);
        _notifyOnRemediation  = ParseBool(await GetStoredAsync("adf:settings:notifyOnRemediation"), false);

        // Email settings overrides
        try { await LoadEmailSettingsAsync(); }
        catch { /* non-fatal — fields stay empty */ }

        // Display — reflect current LayoutState (already loaded from localStorage by MainLayout)
        _refreshInterval = LayoutState.RefreshIntervalSeconds;
    }

    // ── localStorage helpers ──────────────────────────────────────────────────

    private async Task<string?> GetStoredAsync(string key)
    {
        try   { return await JS.InvokeAsync<string?>("localStorage.getItem", key); }
        catch { return null; }
    }

    private async Task SetStoredAsync(string key, string value)
    {
        try   { await JS.InvokeVoidAsync("localStorage.setItem", key, value); }
        catch { /* ignore storage errors */ }
    }

    private async Task RemoveStoredAsync(string key)
    {
        try   { await JS.InvokeVoidAsync("localStorage.removeItem", key); }
        catch { /* ignore storage errors */ }
    }

    private static bool ParseBool(string? raw, bool fallback)
        => raw is not null && bool.TryParse(raw, out var v) ? v : fallback;

    // ── Connection actions ────────────────────────────────────────────────────

    private async Task SaveConnectionAsync()
    {
        _savingConnection = true;
        try
        {
            var url = string.IsNullOrWhiteSpace(_apiBaseUrl) ? null : _apiBaseUrl.Trim();
            var key = string.IsNullOrWhiteSpace(_apiKey)     ? null : _apiKey;

            // Persist to localStorage
            if (url is not null) await SetStoredAsync("adf:settings:apiBaseUrl", url);
            else                 await RemoveStoredAsync("adf:settings:apiBaseUrl");

            if (key is not null) await SetStoredAsync("adf:settings:apiKey", key);
            else                 await RemoveStoredAsync("adf:settings:apiKey");

            // Apply immediately to the in-memory override service.
            DashboardSettings.ApiBaseUrl = url;
            DashboardSettings.ApiKey     = key;

            Snackbar.Add("Connection settings saved.", Severity.Success);
        }
        finally
        {
            _savingConnection = false;
        }
    }

    private async Task RunTestConnectionAsync()
    {
        _testingConnection = true;
        try
        {
            var result = await ApiClient.TestConnectionAsync(_cts.Token);
            LayoutState.SetApiConnected(result.Success);
            Snackbar.Add(result.Message, result.Success ? Severity.Success : Severity.Error);
        }
        finally
        {
            _testingConnection = false;
        }
    }

    private async Task ClearConnectionOverridesAsync()
    {
        _apiBaseUrl = string.Empty;
        _apiKey     = string.Empty;
        DashboardSettings.ApiBaseUrl = null;
        DashboardSettings.ApiKey     = null;
        await RemoveStoredAsync("adf:settings:apiBaseUrl");
        await RemoveStoredAsync("adf:settings:apiKey");
        Snackbar.Add("Connection overrides cleared — appsettings.json defaults are active.", Severity.Info);
    }

    // ── Notifications actions ─────────────────────────────────────────────────

    private void AddRecipient()
    {
        var email = _newRecipientEmail.Trim();
        if (string.IsNullOrWhiteSpace(email)) return;
        if (!_recipientEmails.Contains(email, StringComparer.OrdinalIgnoreCase))
            _recipientEmails.Add(email);
        _newRecipientEmail = string.Empty;
    }

    private void RemoveRecipient(string email)
    {
        _recipientEmails.RemoveAll(e => string.Equals(e, email, StringComparison.OrdinalIgnoreCase));
    }

    private async Task OnAddEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddRecipient();
    }

    private async Task SaveRecipientsAsync()
    {
        _savingRecipient = true;
        try
        {
            await ApiClient.SetNotificationRecipientsAsync(_recipientEmails, _cts.Token);
            Snackbar.Add("Notification recipients saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save recipients: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingRecipient = false;
        }
    }

    private async Task OnNotificationsEnabledChangedAsync(bool value)
    {
        if (value && _notificationPermission != "granted")
        {
            try { _notificationPermission = await JS.InvokeAsync<string>("adfNotifications.requestPermission"); }
            catch { _notificationPermission = "unsupported"; }

            if (_notificationPermission != "granted")
            {
                Snackbar.Add(
                    _notificationPermission == "denied"
                        ? "Notification permission denied. Allow notifications in your browser settings."
                        : "Notification permission was not granted.",
                    Severity.Warning);
                return; // leave switch off
            }
        }

        _notificationsEnabled = value;
        await SaveNotificationsAsync();
    }

    private async Task SaveNotificationsAsync()
    {
        await SetStoredAsync("adf:settings:notificationsEnabled", _notificationsEnabled.ToString().ToLowerInvariant());
        await SetStoredAsync("adf:settings:notifyOnFailure",      _notifyOnFailure.ToString().ToLowerInvariant());
        await SetStoredAsync("adf:settings:notifyOnApproval",     _notifyOnApproval.ToString().ToLowerInvariant());
        await SetStoredAsync("adf:settings:notifyOnRemediation",  _notifyOnRemediation.ToString().ToLowerInvariant());
    }

    // ── Email settings actions ────────────────────────────────────────────────

    private async Task LoadEmailSettingsAsync()
    {
        _emailSettings = await ApiClient.GetEmailSettingsAsync(_cts.Token);
        if (_emailSettings is null) return;
        _emailSmtpHost         = _emailSettings.SmtpHost;
        _emailSmtpPort         = _emailSettings.SmtpPort;
        _emailUseSsl           = _emailSettings.UseSsl;
        _emailUsername         = _emailSettings.Username;
        _emailPassword         = string.Empty; // never pre-fill password
        _emailFromAddress      = _emailSettings.FromAddress;
        _emailFromName         = _emailSettings.FromName;
        _emailDashboardBaseUrl = _emailSettings.DashboardBaseUrl;
    }

    private async Task SaveEmailSettingsAsync()
    {
        _savingEmailSettings = true;
        try
        {
            var req = new EmailSettingsRequest(
                SmtpHost:         NullIfBlank(_emailSmtpHost),
                SmtpPort:         _emailSmtpPort,
                UseSsl:           _emailUseSsl,
                Username:         NullIfBlank(_emailUsername),
                Password:         NullIfBlank(_emailPassword),
                FromAddress:      NullIfBlank(_emailFromAddress),
                FromName:         NullIfBlank(_emailFromName),
                DashboardBaseUrl: NullIfBlank(_emailDashboardBaseUrl));

            _emailSettings = await ApiClient.SetEmailSettingsAsync(req, _cts.Token);
            _emailPassword = string.Empty; // clear password field after save
            Snackbar.Add("Email settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save email settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingEmailSettings = false;
        }
    }

    private async Task ClearEmailSettingsAsync()
    {
        _savingEmailSettings = true;
        try
        {
            await ApiClient.ClearEmailSettingsAsync(_cts.Token);
            await LoadEmailSettingsAsync();
            Snackbar.Add("Email overrides cleared — server appsettings are now active.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to clear overrides: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingEmailSettings = false;
        }
    }

    private async Task SendTestEmailAsync()
    {
        if (string.IsNullOrWhiteSpace(_testEmailRecipient)) return;
        _sendingTestEmail = true;
        _testEmailResult  = null;
        try
        {
            _testEmailResult = await ApiClient.TestEmailAsync(_testEmailRecipient.Trim(), _cts.Token);
        }
        catch (Exception ex)
        {
            _testEmailResult = (false, $"Request failed: {ex.Message}");
        }
        finally
        {
            _sendingTestEmail = false;
        }
    }

    private async Task OnTestEmailKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendTestEmailAsync();
    }

    private static string? NullIfBlank(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    // ── Display actions ───────────────────────────────────────────────────────

    private async Task SetDarkModeAsync(bool value)
    {
        LayoutState.SetDarkMode(value);
        await SetStoredAsync("adf:settings:darkMode", value.ToString().ToLowerInvariant());
    }

    private async Task SaveRefreshIntervalAsync(int value)
    {
        _refreshInterval = value;
        LayoutState.SetRefreshInterval(value);
        await SetStoredAsync("adf:settings:refreshInterval", value.ToString());
        var label = _refreshOptions.FirstOrDefault(o => o.Value == value).Label ?? $"{value}s";
        Snackbar.Add($"Refresh interval set to {label}.", Severity.Info);
    }

    // ── Dispose ───────────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
