{
  // Local development overrides — never commit real secrets here.
  // Use `dotnet user-secrets set` for Api:ApiKey / Anthropic:ApiKey / ClientSecret.

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AdfAgentMonitor;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "AzureDataFactory": {
    // Leave TenantId / ClientId / ClientSecret empty locally to use DefaultAzureCredential.
    "LookbackMinutes": 120
  },

  "Hangfire": {
    "SqlConnectionString": ""
  },

  // CORS — local Blazor WASM development origins.
  // Adjust the ports to match your Dashboard launchSettings.json.
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5000",
      "https://localhost:7000",
      "http://localhost:5071",
      "https://localhost:7071"
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
