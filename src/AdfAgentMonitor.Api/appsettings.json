  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "ADF Agent Monitor",
    "DashboardBaseUrl": ""
  },

  // ============================================================================
  // ANTHROPIC / CLAUDE
  // Env vars: ANTHROPIC__APIKEY  ANTHROPIC__MODELID
  // ============================================================================
  "Anthropic": {
    "ApiKey": "",
    "ModelId": "claude-sonnet-4-20250514",
    "Temperature": 0.0,
    "MaxTokens": 1024
  },

  // ============================================================================
  // HANGFIRE  (storage only — no processing server in the Api)
  // Env vars: HANGFIRE__SQLCONNECTIONSTRING
  // ============================================================================
  "Hangfire": {
    "SqlConnectionString": ""
  },

  // ============================================================================
  // API KEY AUTHENTICATION
  // X-Api-Key header value checked on all /api/approvals/* endpoints.
  // NEVER commit a real value to source control.
  // Env var: API__APIKEY
  // ============================================================================
  "Api": {
    "ApiKey": ""
  },

  // ============================================================================
  // CORS — allowed origins for the Blazor PWA dashboard.
  // Add your dashboard URL here (Azure Static Web App, custom domain, etc.).
  // Env vars: CORS__ALLOWEDORIGINS__0  CORS__ALLOWEDORIGINS__1  ...
  // ============================================================================
  "Cors": {
    "AllowedOrigins": []
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
